generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GameType {
  POKEMON
  YUGIOH
  MTG
  ONEPIECE
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  SUPER_RARE
  ULTRA_RARE
  SECRET_RARE
  SPECIAL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  collections Collection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Card {
  id          String   @id @default(cuid())
  externalId  String?
  name        String
  gameType    GameType
  setName     String?
  setCode     String?
  rarity      Rarity?
  imageUrl    String?
  marketPrice Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pokemonDetails PokemonCardDetails?
  yugiohDetails  YugiohCardDetails?
  mtgDetails     MtgCardDetails?
  onepieceDetails OnePieceCardDetails?
  collectionCards CollectionCard[]

  @@index([gameType])
  @@index([name])
  @@map("cards")
}

model PokemonCardDetails {
  id          String  @id @default(cuid())
  cardId      String  @unique
  hp          Int?
  types       String[] // e.g. ["Fire", "Water"]
  evolvesFrom String?
  stage       String? // Basic, Stage 1, Stage 2
  weakness    String?
  resistance  String?
  retreatCost Int?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("pokemon_card_details")
}

model YugiohCardDetails {
  id        String  @id @default(cuid())
  cardId    String  @unique
  cardType  String? // Monster, Spell, Trap
  attribute String?
  level     Int?
  attack    Int?
  defense   Int?
  race      String? // Warrior, Spellcaster, etc.
  archetype String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("yugioh_card_details")
}

model MtgCardDetails {
  id         String  @id @default(cuid())
  cardId     String  @unique
  manaCost   String?
  cmc        Float?
  colors     String[] // e.g. ["W", "U"]
  typeLine   String?
  oracleText String?
  power      String?
  toughness  String?
  loyalty    String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("mtg_card_details")
}

model OnePieceCardDetails {
  id        String  @id @default(cuid())
  cardId    String  @unique
  color     String?
  cost      Int?
  power     Int?
  counter   Int?
  attribute String?
  cardType  String? // Leader, Character, Event, Stage

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("onepiece_card_details")
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  gameType  GameType
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards CollectionCard[]

  @@index([userId])
  @@map("collections")
}

model CollectionCard {
  id           String   @id @default(cuid())
  collectionId String
  cardId       String
  quantity     Int      @default(1)
  condition    String?  // Mint, Near Mint, Lightly Played, etc.
  notes        String?
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([collectionId, cardId])
  @@map("collection_cards")
}
