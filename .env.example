# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# NextAuth
AUTH_SECRET="" # Generate with: npx auth secret
AUTH_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app" # Used by billing actions for redirect URLs

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET="" # From Stripe webhook endpoint config
STRIPE_MASTER_PRICE_ID="" # Price ID for the premium subscription

# Sentry (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN="" # Client-side DSN (public)
SENTRY_ORG=""
SENTRY_PROJECT=""

# Cron job authentication
CRON_SECRET="" # Shared secret for /api/cron/* routes (set in vercel.json headers)

# Pokemon TCG API (optional — falls back to GitHub raw data)
POKEMON_TCG_API_KEY="" # From https://dev.pokemontcg.io
