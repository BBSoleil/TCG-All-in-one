# Database (Supabase PostgreSQL — use session pooler on port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Site URL — used by metadata, robots.txt, sitemap.xml, billing redirects
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# NextAuth
AUTH_SECRET="" # Generate with: npx auth secret
AUTH_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app" # Used by billing actions for redirect URLs

# Admin gate (e.g. access to /debug). Set to the exact email of the admin user.
ADMIN_EMAIL=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET="" # From Stripe webhook endpoint config
STRIPE_MASTER_PRICE_ID="" # Price ID for the premium subscription

# Vercel Blob (photo uploads — listings, avatars)
# Auto-populated when you add the Blob integration in Vercel dashboard
BLOB_READ_WRITE_TOKEN=""

# Sentry (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN="" # Client-side DSN (public)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN="" # For source map uploads during build (optional but recommended)

# Cron job authentication
CRON_SECRET="" # Shared secret for /api/cron/* routes (set in vercel.json headers)

# Pokemon TCG API (optional — falls back to GitHub raw data)
POKEMON_TCG_API_KEY="" # From https://dev.pokemontcg.io
